<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Checkin" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_app</item>
        <item name="colorSurface">@color/surface_app</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_app</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Checkin" parent="Base.Theme.Checkin" />
</resources>
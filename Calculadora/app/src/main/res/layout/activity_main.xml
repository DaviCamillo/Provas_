<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingTop="16dp">

    <!-- Botão de Menu (Histórico e Bhaskara) -->
    <ImageButton
        android:id="@+id/btn_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_sort_by_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/accent_blue"
        android:contentDescription="Menu" />

    <!-- Visor de Cálculo - Ocupa a parte superior -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/keyboard_grid"
        app:layout_constraintTop_toBottomOf="@+id/btn_menu"
        app:layout_constraintVertical_weight="1"
        app:strokeColor="@color/accent_blue"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="bottom|end"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_formula"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="22sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Teclado - Preenche a parte inferior sem vãos -->
    <GridLayout
        android:id="@+id/keyboard_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:columnCount="4"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_display"
        app:layout_constraintVertical_weight="2.2">

        <Button style="@style/CalcButton.Function" android:text="C" android:id="@+id/btn_clear"/>
        <Button style="@style/CalcButton.Function" android:text="DEL" android:id="@+id/btn_del"/>
        <Button style="@style/CalcButton.Function" android:text="^" android:id="@+id/btn_power"/>
        <Button style="@style/CalcButton.Function" android:text="√" android:id="@+id/btn_root"/>

        <Button style="@style/CalcButton.Number" android:text="7" android:id="@+id/btn_7"/>
        <Button style="@style/CalcButton.Number" android:text="8" android:id="@+id/btn_8"/>
        <Button style="@style/CalcButton.Number" android:text="9" android:id="@+id/btn_9"/>
        <Button style="@style/CalcButton.Operator" android:text="*" android:id="@+id/btn_mul"/>

        <Button style="@style/CalcButton.Number" android:text="4" android:id="@+id/btn_4"/>
        <Button style="@style/CalcButton.Number" android:text="5" android:id="@+id/btn_5"/>
        <Button style="@style/CalcButton.Number" android:text="6" android:id="@+id/btn_6"/>
        <Button style="@style/CalcButton.Operator" android:text="-" android:id="@+id/btn_sub"/>

        <Button style="@style/CalcButton.Number" android:text="1" android:id="@+id/btn_1"/>
        <Button style="@style/CalcButton.Number" android:text="2" android:id="@+id/btn_2"/>
        <Button style="@style/CalcButton.Number" android:text="3" android:id="@+id/btn_3"/>
        <Button style="@style/CalcButton.Operator" android:text="+" android:id="@+id/btn_add"/>

        <Button style="@style/CalcButton.Number" android:text="0" android:id="@+id/btn_0"/>
        <Button style="@style/CalcButton.Number" android:text="." android:id="@+id/btn_dot"/>
        <Button style="@style/CalcButton.Equal" android:text="=" android:id="@+id/btn_equal"/>
        <Button style="@style/CalcButton.Operator" android:text="/" android:id="@+id/btn_div"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

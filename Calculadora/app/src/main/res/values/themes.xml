<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CalculadoraMonstra" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="Theme.CalculadoraMonstra" parent="Base.Theme.CalculadoraMonstra" />

    <style name="CalcButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">26sp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CalcButton.Number">
        <item name="backgroundTint">@color/surface_dark</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="CalcButton.Operator">
        <item name="backgroundTint">@color/accent_orange</item>
        <item name="android:textColor">#121212</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalcButton.Function">
        <item name="backgroundTint">#2A2A2A</item>
        <item name="android:textColor">@color/accent_blue</item>
    </style>

    <style name="CalcButton.Equal">
        <item name="backgroundTint">@color/accent_blue</item>
        <item name="android:textColor">#121212</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalcButton.Bhaskara">
        <item name="backgroundTint">@color/accent_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Space Gradient -->
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#0B0E14"
                android:centerColor="#1A0B2E"
                android:endColor="#2D1B4E"
                android:type="linear" />
        </shape>
    </item>

    <!-- Subtle Nebula Glow -->
    <item>
        <shape>
            <gradient
                android:centerX="0.3"
                android:centerY="0.2"
                android:gradientRadius="400dp"
                android:startColor="#1A4B2C69"
                android:endColor="#00000000"
                android:type="radial" />
        </shape>
    </item>

    <!-- Random Stars -->
    <item android:left="50dp" android:top="80dp">
        <shape android:shape="oval">
            <size android:width="2dp" android:height="2dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:left="200dp" android:top="40dp">
        <shape android:shape="oval">
            <size android:width="3dp" android:height="3dp" />
            <solid android:color="#FFF1A8" />
        </shape>
    </item>
    <item android:left="300dp" android:top="150dp">
        <shape android:shape="oval">
            <size android:width="1.5dp" android:height="1.5dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:left="80dp" android:top="300dp">
        <shape android:shape="oval">
            <size android:width="2dp" android:height="2dp" />
            <solid android:color="#E91E63" />
        </shape>
    </item>
    <item android:left="250dp" android:top="450dp">
        <shape android:shape="oval">
            <size android:width="2.5dp" android:height="2.5dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:left="40dp" android:top="600dp">
        <shape android:shape="oval">
            <size android:width="2dp" android:height="2dp" />
            <solid android:color="#2196F3" />
        </shape>
    </item>
    <item android:left="180dp" android:top="700dp">
        <shape android:shape="oval">
            <size android:width="1dp" android:height="1dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>